{
  "version": 2,
  "claude": {
    "chatListItem": [
      "a[href*='/chat/']"
    ],
    "chatMenuButton": [
      "button[aria-label*='actions' i]",
      "button[aria-haspopup='menu']",
      "button[data-testid*='chat-menu']"
    ],
    "deleteMenuItem": [
      "[role='menuitem']",
      "button[role='menuitem']"
    ],
    "confirmDeleteBtn": [
      "button[data-testid*='confirm']",
      "button.bg-danger",
      "button.bg-red-600",
      "button.danger"
    ]
  },
  "chatgpt": {
    "chatListItem": [
      "a[href*='/c/']"
    ],
    "chatMenuButton": [
      "button[data-testid*='history-item-options']",
      "button[aria-haspopup='menu']",
      "button[aria-label*='options' i]",
      "button[aria-label*='More' i]"
    ],
    "deleteMenuItem": [
      "[role='menuitem']",
      "button[role='menuitem']"
    ],
    "confirmDeleteBtn": [
      "button[data-testid*='delete']",
      "button.btn-danger",
      "button.bg-red-600"
    ]
  },
  "gemini": {
    "chatListItem": [
      "a[href*='/app/']",
      "conversation-list-item a",
      "a[href*='/chat/']"
    ],
    "chatMenuButton": [
      "button[aria-label*='More' i]",
      "button[aria-label*='options' i]",
      "button[aria-label*='actions' i]",
      "button[aria-haspopup='menu']",
      "button[aria-haspopup='true']"
    ],
    "deleteMenuItem": [
      "[role='menuitem']",
      "button[role='menuitem']"
    ],
    "confirmDeleteBtn": [
      "button[data-test-id*='confirm']",
      "button.danger"
    ]
  }
}
