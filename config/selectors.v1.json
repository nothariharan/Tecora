{
  "version": 1,
  "claude": {
    "chatListItem": [
      "a[href*='/chat/']"
    ],
    "chatMenuButton": [
      "button[aria-label*='actions']",
      "button[aria-haspopup='menu']"
    ],
    "deleteMenuItem": [
      "div[role='menuitem']",
      "button[role='menuitem']"
    ],
    "confirmDeleteBtn": [
      "button.bg-red-600",
      "button.danger",
      "button"
    ]
  },
  "chatgpt": {
    "chatListItem": [
      "a[href*='/c/']"
    ],
    "chatMenuButton": [
      "button[aria-haspopup='menu']",
      "button[data-testid*='actions']",
      "button"
    ],
    "deleteMenuItem": [
      "div[role='menuitem']",
      "button[role='menuitem']"
    ],
    "confirmDeleteBtn": [
      "button.bg-red-600",
      "button.btn-danger",
      "button"
    ]
  },
  "gemini": {
    "chatListItem": [
      "a[href*='/app/']",
      "a[href*='/chat/']"
    ],
    "chatMenuButton": [
      "button[aria-haspopup='true']",
      "button[aria-label*='options']",
      "button[aria-label*='actions']"
    ],
    "deleteMenuItem": [
      "[role='menuitem']",
      "button",
      "div"
    ],
    "confirmDeleteBtn": [
      "button",
      "button.danger"
    ]
  }
}
